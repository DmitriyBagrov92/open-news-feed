# ─────────────────────────────────────────────────────────────────────────────
# Meridian — environment configuration
#
# Copy this file to `.env` and fill in what you have. `.env` is gitignored.
# EVERYTHING here is optional: the app works out of the box with keyless RSS
# sources. Keys only unlock extra sources and better AI features.
#
# On Railway, set these as service Variables instead of a file.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
# How often to refresh sources, in minutes (default 5)
REFRESH_MINUTES=5
# Set to 0 when the app is exposed directly WITHOUT a reverse proxy
# (default assumes one trusted proxy, as on Railway)
TRUST_PROXY=

# ── Optional news APIs (each enables an extra source when present) ───────────
# GNews        → https://gnews.io
GNEWS_API_KEY=
# The Guardian Open Platform → https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=
# The New York Times → https://developer.nytimes.com
NYT_API_KEY=
# NewsData.io  → https://newsdata.io
NEWSDATA_API_KEY=
# Currents API → https://currentsapi.services
CURRENTS_API_KEY=

# ── AI summarization ─────────────────────────────────────────────────────────
# Summaries are FREE and run on the user's device: the browser's built-in
# Summarizer API (Chrome/Edge, on-device) with a local extractive fallback
# for other browsers. No keys, no server cost.
#
# Server-side LLM summarization (Claude / Groq / Gemini) is a planned PREMIUM
# feature — not part of the current version. See README → Roadmap.

# ── Optional translation fallback ────────────────────────────────────────────
# Primary translation is the browser's built-in Translator API (Chrome,
# on-device, free). These are server-side fallbacks for other browsers.
# Self-hosted or hosted LibreTranslate instance, e.g. https://libretranslate.com
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
